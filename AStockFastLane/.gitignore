# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local environment and secrets
.env
.env.*
*.local

# IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Build and packaging output
build/
dist/
*.egg-info/

# Runtime logs
*.log
logs/

# Generated probe/cache/evidence/report artifacts
data/raw/*
data/cache/*
data/evidence/*
data/manual/*
reports/*

# Keep manual input directory trackable if placeholder files are added later
!data/manual/
!data/manual/.gitkeep

# Keep directory placeholders trackable if added later
!data/raw/.gitkeep
!data/cache/.gitkeep
!data/evidence/.gitkeep
!reports/.gitkeep
